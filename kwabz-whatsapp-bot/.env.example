# Kwabz Store WhatsApp Bot Configuration

# Admin Phone Number (With country code, NO plus sign, e.g., 233541234567)
ADMIN_PHONE=233540000000

# Storefront URL for dynamic links
STORE_URL=https://kwabz-store-v2.vercel.app

# Firebase Configuration Path (Default is firebase-service-account.json in the same folder)
FIREBASE_SERVICE_ACCOUNT=./firebase-service-account.json
