rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── Helper Functions ───────────────────────────────────
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'admin@kwabzstore.com' ||
        request.auth.token.email == 'admin@kwabz.com' ||
        request.auth.token.email == 'kelvin@kwabz.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isSuperAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'admin@kwabzstore.com' ||
        request.auth.token.email == 'admin@kwabz.com' ||
        request.auth.token.email == 'kelvin@kwabz.com'
      );
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isSeller() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'seller'
      );
    }

    // ─── Store Content (Public Read, Admin Write) ───────────
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() || (
        isSeller() && 
        request.resource.data.seller_id == request.auth.uid
      );
      allow update: if isAdmin() || (
        isSeller() && 
        resource.data.seller_id == request.auth.uid && 
        request.resource.data.seller_id == request.auth.uid
      ) || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'in_stock'])
      );
      allow delete: if isAdmin() || (
        isSeller() && 
        resource.data.seller_id == request.auth.uid
      );
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /sellers/{sellerId} {
      allow read: if true;
      allow create: if isAdmin() || (
        isSeller() && 
        request.auth.uid == sellerId &&
        request.resource.data.commission == 10
      );
      allow update: if isAdmin() || (
        isSeller() && 
        request.auth.uid == sellerId &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['commission']))
      );
      allow delete: if isAdmin();
    }

    match /promo_codes/{promoId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['total_discounted', 'active'])
      );
    }

    match /broadcasts/{broadcastId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Admin-Seller Communications ─────────────────────────
    match /communications/{commId} {
      // Admins can do everything
      allow read, write: if isAdmin();
      
      // Sellers can read broadcasts or their own 1-on-1s
      allow read: if isSeller() && (
        resource.data.receiver_id == 'all' || 
        resource.data.conversation_id == request.auth.uid
      );
      
      // Sellers can send messages to admin
      allow create: if isSeller() && 
        request.resource.data.sender_id == request.auth.uid && 
        request.resource.data.receiver_id == 'admin';
        
      // Sellers can edit their text or update read_by receipts
      allow update: if isSeller() && (
        (resource.data.sender_id == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['message'])) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read_by']))
      );
      
      // Sellers can delete their own messages
      allow delete: if isSeller() && resource.data.sender_id == request.auth.uid;
    }

    match /user_chats/{chatId} {
      allow read: if isAdmin() || (request.auth != null && (resource == null || resource.data.user_id == request.auth.uid));
      allow create: if true;
      allow update, delete: if isAdmin() || (request.auth != null && (resource == null || resource.data.user_id == request.auth.uid));
    }

    match /blog_posts/{postId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'likes', 'liked_by', 'comment_count']);
    }

    match /blog_comments/{commentId} {
      allow read, create: if true;
      allow update, delete: if isAdmin() || (request.auth != null && resource.data.user_id == request.auth.uid);
    }

    match /page_views/{pageName} {
      allow read: if true;
      allow write: if true;
    }

    // ─── Orders (Guest Create, Owner/Admin Read) ────────────
    match /orders/{orderId} {
      allow create: if true;
      allow read: if isAdmin() || (request.auth != null && (
        resource.data.customer_uid == request.auth.uid ||
        resource.data.seller_id == request.auth.uid
      ));
      allow update: if isAdmin() || (request.auth != null && (
        resource.data.customer_uid == request.auth.uid ||
        resource.data.seller_id == request.auth.uid
      ));
      allow delete: if isAdmin() || (request.auth != null && (
        resource.data.customer_uid == request.auth.uid ||
        resource.data.seller_id == request.auth.uid
      ));
    }

    // ─── User Profiles & Carts (Owner/Admin Only) ───────────
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin() || isSuperAdmin();
      
      match /{allPaths=**} {
        allow read, write: if isOwner(userId) || isAdmin() || isSuperAdmin();
      }
    }

    // ─── Presence (Public Read, Owner/Admin Write) ──────────
    match /presence/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }
    
    // ─── Reviews (Public Read, Authenticated Write/Likes, Admin Full Control) ───
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if true; // Support guest reviews
      allow update: if request.auth != null && (
        isAdmin() ||
        // Scenario A: Review Author updating their own post
        (resource.data.user_id == request.auth.uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['user_id', 'product_id', 'verified_purchase'])) ||
        // Scenario B: Other users toggling helpful likes
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'liked_by']))
      );
      allow delete: if isAdmin() || (request.auth != null && resource.data.user_id == request.auth.uid);
    }

    // ─── WhatsApp Bot Accounts (Admin Only) ─────────────────
    match /whatsapp_bot_accounts/{accountId} {
      allow read, write: if isAdmin();
    }

    // ─── WhatsApp Status Requests (Admin Only) ──────────────
    match /status_requests/{requestId} {
      allow read, write: if isAdmin();
    }
    
    // ─── Seller Activation PINs ──────────────────────────────
    match /seller_pins/{pinId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create: if isAdmin() || request.resource.data.status == 'pending';
      allow delete: if isAdmin();
      // Allow updating PIN status from active to used
      allow update: if true; 
    }
    
    // ── Media Library (Admin read/write) ──────────────────────────
    match /media_library/{imageId} {
      allow read, write: if isAdmin() || (
        request.auth != null && (
          (resource == null || resource.data.seller_id == request.auth.uid) &&
          (request.resource == null || request.resource.data.seller_id == request.auth.uid)
        )
      );
    }

    // ── Category Variant Presets (Public read, Admin write) ────────
    match /category_variants/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
